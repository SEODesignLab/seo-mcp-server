{
  "name": "@seodesignlab/mcp-server",
  "version": "1.0.3",
  "description": "MCP server for SEODesignLab's x402-protected SEO endpoints — content briefs, keyword research, SERP analysis, backlink profiles, and on-page audits.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "seodesignlab-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "seo",
    "content-brief",
    "keyword-research",
    "serp-analysis",
    "backlink",
    "audit",
    "x402",
    "seodesignlab"
  ],
  "author": "SEODesignLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SEODesignLab/seo-mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "@types/node": "^20.14.10"
  },
  "mcpName": "io.github.SEODesignLab/seo-tools",
  "engines": {
    "node": ">=18.0.0"
  }
}
